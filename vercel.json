{
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "backend/app/main.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/app/main.py" },
    { "src": "/styles/(.*)", "dest": "/frontend/styles/$1" },
    { "src": "/scripts/(.*)", "dest": "/frontend/scripts/$1" },
    { "src": "/(.*)", "dest": "/frontend/pages/$1" }
  ]
}
